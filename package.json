{
  "name": "campusly",
  "version": "0.0.0",
  "private": true,
  "description": "AnonymousU — verified student social platform (monorepo)",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:api": "npm run dev --workspace @campusly/api",
    "dev:web": "npm run dev --workspace @campusly/web",
    "build:packages": "npm run build --workspace @campusly/shared-types",
    "build:apps": "npm run build --workspace @campusly/api && npm run build --workspace @campusly/web",
    "build": "npm run build:packages && npm run build:apps",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css}": "prettier --write"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
