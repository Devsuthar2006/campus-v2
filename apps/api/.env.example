# AnonymousU API — environment template (SECURITY.md §10).
# Copy to .env and fill in. NEVER commit real secrets.

# Server
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed web origins for CORS
CORS_ORIGINS=http://localhost:3000

# PostgreSQL (DATABASE_SCHEMA.md) — local dev default
DATABASE_URL=postgres://postgres:postgres@localhost:5432/anonymousu

# Logging
LOG_LEVEL=info

# Authentication (AUTH_SYSTEM.md §3–5). NEVER commit real values.
# Google OAuth client ID (institutional Google sign-in)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# JWT signing secrets — generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-min-32-chars-use-openssl-rand
JWT_REFRESH_SECRET=change-me-different-min-32-chars-openssl-rand
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
ACCOUNT_DELETION_GRACE_DAYS=14
# DEV-ONLY: accept any email domain (attaches unrecognized domains to a fallback
# "Open Campus (Dev)" university). MUST be false in production (verified-only).
AUTH_ALLOW_ANY_DOMAIN=false

# Media (MEDIA_SYSTEM.md, ARCHITECTURE.md §9). Bytes in object storage, refs in DB.
# Driver:
#   local — dev disk stand-in (default; needs no cloud config).
#   gcs   — Google Cloud Storage (production; authenticates via ADC — see below).
MEDIA_DRIVER=local
# Signs local upload/download URLs (dev driver). Generate: openssl rand -base64 32
MEDIA_SIGNING_SECRET=change-me-min-16-chars
MEDIA_LOCAL_DIR=.media-storage
MEDIA_PUBLIC_BASE_URL=http://localhost:4000
# Signed-URL validity in seconds — applies to both upload and download URLs
# (used by every driver, including gcs).
MEDIA_URL_TTL_SECONDS=600
MEDIA_TEMP_TTL_HOURS=48

# --- Google Cloud Storage (only when MEDIA_DRIVER=gcs) ------------------------
# Leave unset for local development (MEDIA_DRIVER=local ignores these).
# Authentication uses Application Default Credentials (ADC):
#   Production (GCE VM): the VM's attached service account is used automatically.
#                        No service-account JSON file is required or mounted.
#   Local dev (off-GCP): optionally export GOOGLE_APPLICATION_CREDENTIALS with the
#                        path to a service-account JSON; ADC picks it up. This is
#                        optional and only needed when running the gcs driver
#                        outside GCP. Do NOT commit key files.
# Target bucket name (no 'gs://' prefix, no URL). Required when MEDIA_DRIVER=gcs.
GCS_BUCKET=your-media-bucket-name
# GCP project ID. Optional — ADC usually resolves it; set to pin explicitly.
GCS_PROJECT_ID=your-gcp-project-id
